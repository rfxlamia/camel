# ─────────────────────────────────────────────────────────────────────────────
# camel-kanban (server) — environment variables
#
# Copy this file to `server/.env` (git-ignored) and fill in the values:
#     cp server/.env.example server/.env
#
# Loaded automatically via `import "dotenv/config"` (server/src/index.ts and
# server/src/db/pool.ts). dotenv reads `.env` from the process cwd — the server,
# `db:migrate`, and `db:seed` all run from the server/ workspace, so keep this
# file at server/.env.
#
# DATABASE_URL is required (no built-in fallback). REDIS_URL and PORT have
# defaults below; ANTHROPIC_* vars are required for the agent feature.
# ─────────────────────────────────────────────────────────────────────────────

# ── Server ───────────────────────────────────────────────────────────────────
# Port the Express API listens on (client dev server is :5173).
PORT=3001

# Comma-separated list of allowed CORS origins. Defaults to http://localhost:5173
# in development. In production, all cross-origin requests are denied if unset.
# CORS_ORIGIN=https://app.example.com,https://admin.example.com

# PostgreSQL connection. Default matches `npm run db:up` (docker-compose).
DATABASE_URL=postgres://camel:camel@localhost:5432/camel_kanban

# Redis for SSE pub/sub fan-out. App degrades to in-process fan-out if unreachable.
REDIS_URL=redis://localhost:6379

# ── Agent / LLM (Phase 1) ────────────────────────────────────────────────────
# Required for agent card execution. Without it, executeCard throws at runtime.
ANTHROPIC_API_KEY=

# Optional. Unset → real Anthropic API (api.anthropic.com).
# Set to point at an Anthropic-compatible endpoint. The SDK appends "/v1/messages",
# so use the base WITHOUT a trailing slash and WITHOUT "/v1/messages".
# ANTHROPIC_BASE_URL=

# Optional. Defaults to claude-sonnet-4-6. Override when the endpoint remaps model ids.
# ANTHROPIC_MODEL=claude-sonnet-4-6

# ── Agent tools ──────────────────────────────────────────────────────────────
# Tavily API key for the agent's web_search tool. Without it, web_search returns
# ENV_VAR_MISSING and research cards fail every search. Get one at https://tavily.com
TAVILY_API_KEY=

# ── Example: MiMo (Xiaomi) Anthropic-compatible endpoint ─────────────────────
# Uncomment these three and put your MiMo key in ANTHROPIC_API_KEY above.
# MiMo reads the `api-key` header (the server sends it via defaultHeaders) and
# does NOT support Claude-only thinking/cache_control — the server gates those
# behind "real Anthropic only", so MiMo requests stay on the basic Messages API.
# ANTHROPIC_BASE_URL=https://token-plan-sgp.xiaomimimo.com/anthropic
# ANTHROPIC_MODEL=mimo-v2.5-pro
# ANTHROPIC_API_KEY=your-mimo-api-key
