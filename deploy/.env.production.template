# Copy this to .env.production and fill in values
# NEVER commit .env.production to git

# ── Database ──────────────────────────────────────────────────────────────────
DB_PASSWORD=change_me_strong_password

# ── Agent / LLM ───────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=your_api_key_here
ANTHROPIC_BASE_URL=https://your-llm-provider/anthropic
ANTHROPIC_MODEL=your-model-name

# ── Agent tools ───────────────────────────────────────────────────────────────
TAVILY_API_KEY=

# ── Auth ──────────────────────────────────────────────────────────────────────
BETTER_AUTH_SECRET=change_me_64_char_random_string
CSRF_SECRET=change_me_run_openssl_rand_base64_32

# ── OAuth ─────────────────────────────────────────────────────────────────────
OAUTH_ENABLED=false
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ── Feature flags ─────────────────────────────────────────────────────────────
EMAIL_GATE_ENABLED=false
